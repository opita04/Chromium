{
  "manifest_version": 3,
  "name": "Obsidian Bookmark Saver",
  "description": "Save the current page title and URL to categorized Markdown files in your Obsidian vault.",
  "version": "1.0.0",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "Save to Obsidian Bookmarks",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  }
}
