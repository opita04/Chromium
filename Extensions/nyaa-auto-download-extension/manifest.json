{
  "manifest_version": 3,
  "name": "Nyaa Auto Download",
  "version": "1.1.2",
  "description": "Automatically track and download anime episodes from Nyaa.si",
  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://nyaa.si/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://nyaa.si/*"],
      "js": ["content/content-script.js"],
      "css": ["content/content-styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Nyaa Auto Download",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*.css", "icons/*.png"],
      "matches": ["https://nyaa.si/*"]
    }
  ]
}
