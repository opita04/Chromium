{
  "manifest_version": 3,
  "name": "YouTube Summary Overlay",
  "description": "Extract YouTube transcripts, summarize via OpenRouter, show in a page overlay, and save Markdown to Obsidian.",
  "version": "0.1.0",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.mistral.ai/*",
    "https://grok.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Summarize YouTube video",
    "default_icon": {
      "16": "assets/icon.png",
      "32": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "icons": {
    "16": "assets/icon.png",
    "32": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content/youtube-transcript.js"
      ]
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.mistral.ai/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content/ai-content-script.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/model-icons/*"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
